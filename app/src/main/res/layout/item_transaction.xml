<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.MarketWatch.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_small"
    android:layout_marginVertical="@dimen/spacing_xs"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_medium">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivTransactionIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/colorSurfaceVariant"
            android:padding="@dimen/spacing_small"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
            tools:src="@android:drawable/ic_menu_save" />

        <TextView
            android:id="@+id/tvTransactionTitle"
            style="@style/TextAppearance.MarketWatch.Title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_medium"
            android:textSize="@dimen/text_body_medium"
            app:layout_constraintEnd_toStartOf="@+id/tvTransactionAmount"
            app:layout_constraintStart_toEndOf="@id/ivTransactionIcon"
            app:layout_constraintTop_toTopOf="@id/ivTransactionIcon"
            tools:text="Buy AAPL" />

        <TextView
            android:id="@+id/tvTransactionDate"
            style="@style/TextAppearance.MarketWatch.Caption"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_medium"
            app:layout_constraintBottom_toBottomOf="@id/ivTransactionIcon"
            app:layout_constraintEnd_toStartOf="@+id/tvTransactionAmount"
            app:layout_constraintStart_toEndOf="@id/ivTransactionIcon"
            app:layout_constraintTop_toBottomOf="@id/tvTransactionTitle"
            tools:text="Oct 24, 14:30" />

        <TextView
            android:id="@+id/tvTransactionAmount"
            style="@style/TextAppearance.MarketWatch.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_body_medium"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="-$150.00" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>