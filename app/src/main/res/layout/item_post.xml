<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.MarketWatch.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_small"
    android:layout_marginVertical="@dimen/spacing_xs">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_medium">

        <!-- User Header -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/postUserProfileImage"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
            tools:src="@drawable/ic_account_circle" />

        <TextView
            android:id="@+id/postUserName"
            style="@style/TextAppearance.MarketWatch.Title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_small"
            android:textSize="@dimen/text_body_medium"
            app:layout_constraintEnd_toStartOf="@+id/postMenuButton"
            app:layout_constraintStart_toEndOf="@id/postUserProfileImage"
            app:layout_constraintTop_toTopOf="@id/postUserProfileImage"
            tools:text="User Name" />

        <TextView
            android:id="@+id/postTimestamp"
            style="@style/TextAppearance.MarketWatch.Caption"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_small"
            app:layout_constraintEnd_toStartOf="@+id/postMenuButton"
            app:layout_constraintStart_toEndOf="@id/postUserProfileImage"
            app:layout_constraintTop_toBottomOf="@id/postUserName"
            tools:text="Just now" />

        <ImageButton
            android:id="@+id/postMenuButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@null"
            android:src="@android:drawable/ic_menu_more"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/colorOnSurfaceVariant" />

        <!-- Post Content -->
        <TextView
            android:id="@+id/postContent"
            style="@style/TextAppearance.MarketWatch.Body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_medium"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/postUserProfileImage"
            tools:text="This is a premium post content that looks great on the new UI." />

        <!-- Optional Image -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/postImageCard"
            android:layout_width="0dp"
            android:layout_height="200dp"
            android:layout_marginTop="@dimen/spacing_medium"
            android:visibility="gone"
            app:cardCornerRadius="@dimen/radius_medium"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/postContent"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant">

            <ImageView
                android:id="@+id/postImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="centerCrop" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Interaction Bar -->
        <ImageButton
            android:id="@+id/btnLike"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="@dimen/spacing_medium"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@null"
            android:src="@android:drawable/btn_star_big_off"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/postImageCard"
            app:tint="?attr/colorOnSurfaceVariant" />

        <TextView
            android:id="@+id/tvLikeCount"
            style="@style/TextAppearance.MarketWatch.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_small"
            app:layout_constraintBottom_toBottomOf="@id/btnLike"
            app:layout_constraintStart_toEndOf="@id/btnLike"
            app:layout_constraintTop_toTopOf="@id/btnLike"
            tools:text="0 likes" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>