<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    tools:context=".ProfileFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_medium">

        <!-- Profile Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="@dimen/spacing_xl">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/profileImageView"
                android:layout_width="@dimen/profile_image_size"
                android:layout_height="@dimen/profile_image_size"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_account_circle"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                app:strokeColor="?attr/colorPrimary"
                app:strokeWidth="2dp" />

            <TextView
                android:id="@+id/profileNameTextView"
                style="@style/TextAppearance.MarketWatch.Headline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_medium"
                tools:text="User Name" />

            <TextView
                android:id="@+id/profileEmailTextView"
                style="@style/TextAppearance.MarketWatch.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                tools:text="user@example.com" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/changePictureButton"
                style="@style/Widget.MarketWatch.Button.Tonal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_medium"
                android:text="@string/edit_photo"
                app:icon="@android:drawable/ic_menu_camera" />
        </LinearLayout>

        <!-- Account Section -->
        <TextView
            style="@style/TextAppearance.MarketWatch.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_xs"
            android:layout_marginBottom="@dimen/spacing_small"
            android:text="@string/account_settings"
            android:textColor="?attr/colorPrimary" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.MarketWatch.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_large"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/changeNameButton"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical|start"
                    android:paddingHorizontal="@dimen/spacing_medium"
                    android:text="@string/update_display_name"
                    android:textColor="?attr/colorOnSurface"
                    app:icon="@drawable/ic_account_circle"
                    app:iconPadding="@dimen/spacing_medium"
                    app:iconTint="?attr/colorOnSurfaceVariant" />

                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="56dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/changePasswordButton"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical|start"
                    android:paddingHorizontal="@dimen/spacing_medium"
                    android:text="@string/security_password"
                    android:textColor="?attr/colorOnSurface"
                    app:icon="@android:drawable/ic_lock_lock"
                    app:iconPadding="@dimen/spacing_medium"
                    app:iconTint="?attr/colorOnSurfaceVariant" />

                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="56dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/myPostsButton"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical|start"
                    android:paddingHorizontal="@dimen/spacing_medium"
                    android:text="@string/my_community_posts"
                    android:textColor="?attr/colorOnSurface"
                    app:icon="@android:drawable/ic_menu_agenda"
                    app:iconPadding="@dimen/spacing_medium"
                    app:iconTint="?attr/colorOnSurfaceVariant" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Preferences Section -->
        <TextView
            style="@style/TextAppearance.MarketWatch.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_xs"
            android:layout_marginBottom="@dimen/spacing_small"
            android:text="@string/app_preferences"
            android:textColor="?attr/colorPrimary" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.MarketWatch.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_large"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Currency Row -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="72dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/setCurrencyButton"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical|start"
                        android:paddingHorizontal="@dimen/spacing_medium"
                        android:text="@string/preferred_currency"
                        android:textColor="?attr/colorOnSurface"
                        app:icon="@android:drawable/ic_menu_today"
                        app:iconPadding="@dimen/spacing_medium"
                        app:iconTint="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/profileCurrencyTextView"
                        style="@style/TextAppearance.MarketWatch.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/spacing_large"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="@dimen/text_body_medium"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="USD" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="56dp" />

                <!-- Timezone Row -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="72dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/setTimezoneButton"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical|start"
                        android:paddingHorizontal="@dimen/spacing_medium"
                        android:text="@string/display_timezone"
                        android:textColor="?attr/colorOnSurface"
                        app:icon="@android:drawable/ic_menu_recent_history"
                        app:iconPadding="@dimen/spacing_medium"
                        app:iconTint="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/profileTimezoneTextView"
                        style="@style/TextAppearance.MarketWatch.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/spacing_large"
                        android:ellipsize="end"
                        android:maxWidth="120dp"
                        android:singleLine="true"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="@dimen/text_body_medium"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="UTC" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="56dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/resetWalletButton"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical|start"
                    android:paddingHorizontal="@dimen/spacing_medium"
                    android:text="@string/reset_wallet_data"
                    android:textColor="?attr/colorOnSurface"
                    app:icon="@android:drawable/ic_menu_rotate"
                    app:iconPadding="@dimen/spacing_medium"
                    app:iconTint="?attr/colorOnSurfaceVariant" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Danger Zone -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.MarketWatch.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="100dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorError"
            app:strokeWidth="1dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/deleteAccountButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:gravity="center_vertical|start"
                android:paddingHorizontal="@dimen/spacing_medium"
                android:text="@string/delete_my_account"
                android:textColor="?attr/colorError"
                app:icon="@android:drawable/ic_menu_delete"
                app:iconPadding="@dimen/spacing_medium"
                app:iconTint="?attr/colorError" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>