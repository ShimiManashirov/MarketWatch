<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    tools:context=".SearchFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Search Header -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:elevation="0dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_medium"
                android:layout_marginVertical="@dimen/spacing_small"
                app:cardCornerRadius="@dimen/radius_extra_large"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp">

                <androidx.appcompat.widget.SearchView
                    android:id="@+id/stockSearchView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:iconifiedByDefault="false"
                    app:queryHint="@string/search_hint"
                    app:queryBackground="@android:color/transparent"
                    app:searchIcon="@android:drawable/ic_menu_search" />
            </com.google.android.material.card.MaterialCardView>
        </com.google.android.material.appbar.AppBarLayout>

        <!-- Search States Container -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Progress State -->
            <ProgressBar
                android:id="@+id/searchProgressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />

            <!-- Shimmer Loading State -->
            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/searchShimmerContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="@dimen/spacing_medium"
                android:visibility="gone"
                app:shimmer_auto_start="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <include layout="@layout/item_stock_search_shimmer" />
                    <include layout="@layout/item_stock_search_shimmer" />
                    <include layout="@layout/item_stock_search_shimmer" />
                    <include layout="@layout/item_stock_search_shimmer" />
                </LinearLayout>
            </com.facebook.shimmer.ShimmerFrameLayout>

            <!-- Empty/Suggestions State -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/emptySearchContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_xl">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:alpha="0.2"
                        android:contentDescription="@null"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="?attr/colorOnSurface" />

                    <TextView
                        style="@style/TextAppearance.MarketWatch.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_medium"
                        android:text="@string/discover_market" />

                    <TextView
                        style="@style/TextAppearance.MarketWatch.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_small"
                        android:text="@string/search_description"
                        android:textAlignment="center" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_large"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            style="@style/TextAppearance.MarketWatch.Caption"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/recent_searches" />

                        <TextView
                            android:id="@+id/clearHistoryText"
                            style="@style/TextAppearance.MarketWatch.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/clear_button"
                            android:clickable="true"
                            android:focusable="true"
                            android:textColor="?attr/colorPrimary" />
                    </LinearLayout>

                    <!-- Quick Suggestion Chips -->
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/suggestionChipGroup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_small"
                        app:chipSpacingHorizontal="@dimen/spacing_small">

                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MarketWatch.Chip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AAPL" />
                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MarketWatch.Chip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TSLA" />
                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MarketWatch.Chip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BTC" />
                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MarketWatch.Chip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NVDA" />
                    </com.google.android.material.chip.ChipGroup>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <!-- Results State -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/searchRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="88dp"
                android:visibility="gone" />

        </FrameLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>