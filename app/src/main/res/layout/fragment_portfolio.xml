<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    tools:context=".PortfolioFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_medium">

            <TextView
                style="@style/TextAppearance.MarketWatch.Headline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_medium"
                android:text="Investment Portfolio" />

            <!-- Summary Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/portfolioSummaryCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_large"
                app:cardCornerRadius="@dimen/radius_extra_large"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorPrimary"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_large">
                    
                    <TextView
                        style="@style/TextAppearance.MarketWatch.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Balance"
                        android:textColor="#E0E0E0" />
                    
                    <TextView
                        android:id="@+id/tvTotalBalance"
                        style="@style/TextAppearance.MarketWatch.Headline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/white"
                        android:textSize="@dimen/text_display_small"
                        tools:text="$12,540.00" />

                    <TextView
                        android:id="@+id/tvTotalBalanceIls"
                        style="@style/TextAppearance.MarketWatch.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#E0E0E0"
                        tools:text="≈ ₪46,320.00" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/spacing_medium"
                        android:background="#40FFFFFF" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                style="@style/TextAppearance.MarketWatch.Caption"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cash"
                                android:textColor="#E0E0E0" />
                            <TextView
                                android:id="@+id/tvCashBalance"
                                style="@style/TextAppearance.MarketWatch.Title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@android:color/white"
                                android:textSize="@dimen/text_body_medium"
                                tools:text="$2,400.00" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                style="@style/TextAppearance.MarketWatch.Caption"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Profit"
                                android:textColor="#E0E0E0" />
                            <TextView
                                android:id="@+id/tvTotalProfit"
                                style="@style/TextAppearance.MarketWatch.Title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@android:color/white"
                                android:textSize="@dimen/text_body_medium"
                                tools:text="+$1,250.00" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Allocation Chart Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/portfolioChartCard"
                style="@style/Widget.MarketWatch.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_large"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_medium">
                    
                    <TextView
                        style="@style/TextAppearance.MarketWatch.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Asset Distribution"
                        android:textSize="@dimen/text_body_medium" />

                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/portfolioPieChart"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:layout_marginTop="@dimen/spacing_small" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section 1: My Holdings (Owned) -->
            <LinearLayout
                android:id="@+id/holdingsSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/spacing_xl">

                <TextView
                    android:id="@+id/titleHoldings"
                    style="@style/TextAppearance.MarketWatch.Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Portfolio Holdings"
                    android:textColor="?attr/colorPrimary" />
                
                <TextView
                    style="@style/TextAppearance.MarketWatch.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stocks you currently own" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/portfolioRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_medium"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>

            <View
                android:id="@+id/sectionDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="@dimen/spacing_large"
                android:background="?attr/colorOutlineVariant" />

            <!-- Section 2: Watchlist (Favorites) -->
            <LinearLayout
                android:id="@+id/watchlistSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/titleWatchlist"
                    style="@style/TextAppearance.MarketWatch.Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Watchlist"
                    android:textColor="?attr/colorSecondary" />

                <TextView
                    style="@style/TextAppearance.MarketWatch.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stocks you are following" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/watchlistRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_medium"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="100dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/portfolioProgressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/emptyPortfolioText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/spacing_xl"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:alpha="0.3"
            android:contentDescription="@null"
            android:src="@android:drawable/ic_menu_search"
            app:tint="?attr/colorOnSurface" />

        <TextView
            style="@style/TextAppearance.MarketWatch.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_medium"
            android:text="Your portfolio is empty" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>