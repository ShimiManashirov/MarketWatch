<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/stockDetailsToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="?attr/homeAsUpIndicator">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageButton
                        android:id="@+id/priceAlertButton"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@null"
                        android:src="@android:drawable/ic_lock_idle_alarm"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <ImageButton
                        android:id="@+id/favoriteStarButton"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="@dimen/spacing_small"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@null"
                        android:src="@android:drawable/btn_star_big_off"
                        app:tint="?attr/colorPrimary" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.appbar.MaterialToolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/stockDetailsShimmer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_large">
            <View
                android:layout_width="150dp"
                android:layout_height="32dp"
                android:background="?attr/colorOutlineVariant" />
            <View
                android:layout_width="250dp"
                android:layout_height="20dp"
                android:layout_marginTop="@dimen/spacing_small"
                android:background="?attr/colorOutlineVariant" />
            <View
                android:layout_width="200dp"
                android:layout_height="64dp"
                android:layout_marginTop="@dimen/spacing_large"
                android:background="?attr/colorOutlineVariant" />
            <View
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_marginTop="@dimen/spacing_large"
                android:background="?attr/colorOutlineVariant" />
        </LinearLayout>
    </com.facebook.shimmer.ShimmerFrameLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/stockDetailsContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_large">

            <!-- Header Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    app:cardCornerRadius="@dimen/radius_medium"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp">
                    <ImageView
                        android:id="@+id/ivStockLogo"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@null"
                        android:padding="@dimen/spacing_small"
                        android:scaleType="fitCenter" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_medium"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/detailsSymbol"
                        style="@style/TextAppearance.MarketWatch.Headline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="-0.02"
                        tools:text="AAPL" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipIndustry"
                        style="@style/Widget.MarketWatch.Chip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:visibility="gone"
                        app:chipBackgroundColor="?attr/colorPrimaryContainer"
                        app:chipStrokeWidth="0dp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/detailsDescription"
                style="@style/TextAppearance.MarketWatch.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                tools:text="Apple Inc." />

            <!-- Price Information -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/detailsPrice"
                    style="@style/TextAppearance.MarketWatch.Headline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_display_small"
                    tools:text="$182.63" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/detailsChange"
                        style="@style/TextAppearance.MarketWatch.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_body_medium"
                        tools:text="+1.24 (0.68%)" />

                    <TextView
                        android:id="@+id/detailsPriceIls"
                        style="@style/TextAppearance.MarketWatch.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_medium"
                        tools:text="≈ ₪675.73" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvOwnedShares"
                    style="@style/TextAppearance.MarketWatch.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_medium"
                    android:background="?attr/colorPrimaryContainer"
                    android:paddingHorizontal="@dimen/spacing_medium"
                    android:paddingVertical="@dimen/spacing_xs"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    android:visibility="gone"
                    tools:text="You own 10 shares" />
            </LinearLayout>

            <!-- Chart -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.MarketWatch.Card"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_marginTop="@dimen/spacing_xl"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp">
                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/stockChart"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="@dimen/spacing_medium" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_large"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buyStockButton"
                    style="@style/Widget.MarketWatch.Button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_small"
                    android:text="Buy"
                    app:backgroundTint="@color/market_up" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/sellStockButton"
                    style="@style/Widget.MarketWatch.Button.Tonal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_small"
                    android:text="Sell"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Key Stats -->
            <TextView
                style="@style/TextAppearance.MarketWatch.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:letterSpacing="0.1"
                android:text="KEY STATISTICS" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.MarketWatch.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_medium"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp">
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:padding="@dimen/spacing_medium">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_small">
                        <TextView
                            style="@style/TextAppearance.MarketWatch.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Day High" />
                        <TextView
                            android:id="@+id/detailsHigh"
                            style="@style/TextAppearance.MarketWatch.Title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/text_title_small"
                            tools:text="184.20" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_small">
                        <TextView
                            style="@style/TextAppearance.MarketWatch.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Day Low" />
                        <TextView
                            android:id="@+id/detailsLow"
                            style="@style/TextAppearance.MarketWatch.Title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/text_title_small"
                            tools:text="181.15" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_small">
                        <TextView
                            style="@style/TextAppearance.MarketWatch.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Prev. Close" />
                        <TextView
                            android:id="@+id/detailsPrevClose"
                            style="@style/TextAppearance.MarketWatch.Title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/text_title_small"
                            tools:text="182.50" />
                    </LinearLayout>
                </GridLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Latest News -->
            <TextView
                style="@style/TextAppearance.MarketWatch.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:letterSpacing="0.1"
                android:text="LATEST NEWS" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvStockNews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_medium"
                android:nestedScrollingEnabled="false"
                android:paddingBottom="@dimen/spacing_xl" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>