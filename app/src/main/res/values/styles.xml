<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Standard Card Styles
        Used across the app for a consistent elevation and corner radius.
    -->
    <style name="Widget.MarketWatch.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/radius_medium</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="android:layout_margin">@dimen/spacing_small</item>
    </style>

    <style name="Widget.MarketWatch.Card.Stock" parent="Widget.MarketWatch.Card">
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
        <item name="strokeWidth">@dimen/card_stroke</item>
    </style>

    <!--
        Typography Styles
        Ensures all headers, body text, and captions follow the design grid.
    -->
    <style name="TextAppearance.MarketWatch.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.MarketWatch.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.MarketWatch.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="TextAppearance.MarketWatch.Caption" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">?attr/colorOutline</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!--
        Button Styles
        Custom buttons for consistent height and branding colors.
    -->
    <style name="Widget.MarketWatch.Button" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="cornerRadius">@dimen/radius_medium</item>
    </style>

    <style name="Widget.MarketWatch.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="cornerRadius">@dimen/radius_medium</item>
    </style>

    <style name="Widget.MarketWatch.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">?attr/colorPrimary</item>
    </style>

    <!--
        Input Field Styles
        Standardizes the appearance of login and registration inputs.
    -->
    <style name="Widget.MarketWatch.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/radius_medium</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_medium</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_medium</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_medium</item>
        <item name="android:layout_marginBottom">@dimen/spacing_medium</item>
    </style>

    <!--
        Chip Styles
        Used for market sectors and search history.
    -->
    <style name="Widget.MarketWatch.Chip" parent="Widget.Material3.Chip.Suggestion">
        <item name="chipCornerRadius">@dimen/radius_round</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

</resources>
